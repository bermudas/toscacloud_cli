# ─────────────────────────────────────────────────────────────
# TOSCA Cloud CLI – connection settings template
#
# Copy this file to .env  OR  configure via:
#   python tosca_cli.py config set --tenant ... --token-url ... \
#       --client-id ... --client-secret ... --space-id ...
#
# Settings are stored in ~/.tosca_cli/config.env
# Local .env supplements but does NOT override ~/.tosca_cli/config.env
# ─────────────────────────────────────────────────────────────

# Tenant root URL  (no trailing slash)
# Example: https://your-org.my.tricentis.com
TOSCA_TENANT_URL=https://your-tenant.my.tricentis.com

# Space ID  (UUID visible in the TOSCA Cloud UI URL, or use "default")
# Example URL: https://your-tenant.my.tricentis.com/<space-uuid>/...
TOSCA_SPACE_ID=your-space-uuid

# OAuth2 token endpoint  (Okta-hosted – NOT the tenant URL)
# How to find it:
#   1. Open  https://your-tenant.my.tricentis.com/_identity/apiDocs/swagger
#   2. Click Authorize – copy the "Token URL" shown in the dialog
# Typical format: https://<org>-tricentis.okta.com/oauth2/default/v1/token
TOSCA_TOKEN_URL=https://your-org-tricentis.okta.com/oauth2/default/v1/token

# OAuth2 client credentials
# How to obtain:
#   1. Run:  python tosca_cli.py identity apps      → note the Id of your app
#   2. Run:  python tosca_cli.py identity secrets <appId>
#   3. Or generate a new secret:  python tosca_cli.py identity new-secret <appId>
TOSCA_CLIENT_ID=your-client-id
TOSCA_CLIENT_SECRET=your-client-secret

# OAuth2 scope (default: tta – do not change unless instructed by Tricentis)
TOSCA_SCOPE=tta

# HTTP timeout in seconds (default: 30)
# TOSCA_TIMEOUT=30

# Set to "false" to disable SSL certificate verification (not recommended for production)
# TOSCA_VERIFY_SSL=true

# OpenAI API key – only required for the `ask` command
# TOSCA_OPENAI_KEY=sk-...
