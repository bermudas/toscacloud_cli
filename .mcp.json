{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },"ToscaCloudMcpServer": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://<YourTenant>.my.tricentis.com/<Workspaceid>/_mcp/api/mcp",
        "56874",
        "--host",
        "127.0.0.1",
        "--static-oauth-client-info",
        "{\"client_id\":\"MCPServer\"}",
        "--static-oauth-client-metadata",
        "{\"scope\":\"tta\"}"
      ]
    }
  }
}
