# ─────────────────────────────────────────────────────────────────────────────
# Tosca Commander CLI — minimal .env template for the trial
#
# Usage:  cp .env.commander.example .env  →  edit values below  →  save
# Verify: python tosca_commander_cli.py config test
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Tosca REST API service.
# Either form is accepted — the CLI auto-appends /rest/toscacommander if missing.
#   self-hosted (Tricentis.Tosca.RestApiService): http://yourhost:1111
#   reverse-proxied via IIS:                       https://yourhost/rest/toscacommander
TOSCA_COMMANDER_BASE_URL=http://your-tosca-server:1111

# Default workspace name. With this set, you don't need to pass --workspace/-w
# on every subcommand.
TOSCA_COMMANDER_WORKSPACE=YourWorkspace


# ─────────────────────────────────────────────────────────────────────────────
# Pick ONE auth combo. Uncomment its lines, leave the others as comments.
# Default mode (auto) picks the first matching combo: PAT → client-creds → Basic.
# ─────────────────────────────────────────────────────────────────────────────

# Auth A — Personal Access Token (recommended)
# Get it from: Tosca Server → your profile → Personal Access Tokens.
# A Tosca Server PAT is a long base64-encoded blob — paste it verbatim, do not decode.
# Wire-level: Authorization: <token>     +     AuthMode: pat
TOSCA_COMMANDER_TOKEN=

# Auth B — Basic / Active Directory (multi-user workspaces, incl. LDAP-backed)
# For AD-backed workspaces, set USER to either:
#   user@DOMAIN.FQDN     (UPN — recommended; matches Tosca Login dialog)
#   DOMAIN\username      (down-level form)
# Wire-level: Authorization: Basic <base64(user:pass)>     (no AuthMode header)
#TOSCA_COMMANDER_USER=user@DOMAIN.FQDN
#TOSCA_COMMANDER_PASSWORD=

# Auth C — Client credentials (Tricentis Server Repository service apps)
# Wire-level: Authorization: Basic <base64(client_id:client_secret)>     +     AuthMode: clientCredentials
# (Plain Basic auth, NOT an OAuth2 token exchange. The /tua/connect/token
#  endpoint is AOS, not TCRS — different service.)
#TOSCA_COMMANDER_CLIENT_ID=
#TOSCA_COMMANDER_CLIENT_SECRET=

# Auth D — IIS Windows Authentication (NTLM/Kerberos via SSPI)
# When this is set to 'negotiate', no USER/PASSWORD/TOKEN is needed —
# the request uses the logged-in Windows session.
#   Python (tosca_commander_cli.py): pip install requests-negotiate-sspi  (Windows-only)
#   PowerShell (trial.ps1):          built-in via Invoke-RestMethod -UseDefaultCredentials
#TOSCA_COMMANDER_AUTH=negotiate

# Auth E — Explicit-cred NTLM (cross-platform)
# Set USER + PASSWORD as for Auth B above.
#   Python (tosca_commander_cli.py): pip install httpx-ntlm
#   PowerShell (trial.ps1):          built-in via Invoke-RestMethod -Credential
#TOSCA_COMMANDER_AUTH=ntlm
#TOSCA_COMMANDER_USER=DOMAIN\you
#TOSCA_COMMANDER_PASSWORD=
