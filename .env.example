# ─────────────────────────────────────────────────────────────
# TOSCA Cloud CLI – connection settings template
#
# Copy this file to .env  OR  configure via:
#   python tosca_cli.py config set --tenant ... --token-url ... \
#       --client-id ... --client-secret ... --space-id ...
#
# Settings are stored in ~/.tosca_cli/config.env
# Local .env supplements but does NOT override ~/.tosca_cli/config.env
# ─────────────────────────────────────────────────────────────

# Tenant root URL  (no trailing slash)
# Example: https://your-org.my.tricentis.com
TOSCA_TENANT_URL=https://your-tenant.my.tricentis.com

# Space ID  (UUID visible in the TOSCA Cloud UI URL, or use "default")
# Example URL: https://your-tenant.my.tricentis.com/<space-uuid>/...
TOSCA_SPACE_ID=your-space-uuid

# OAuth2 token endpoint  (Okta-hosted – NOT the tenant URL)
# How to find it:
#   1. Open  https://your-tenant.my.tricentis.com/_identity/apiDocs/swagger
#   2. Click Authorize – copy the "Token URL" shown in the dialog
# Typical format: https://<org>-tricentis.okta.com/oauth2/default/v1/token
TOSCA_TOKEN_URL=https://your-org-tricentis.okta.com/oauth2/default/v1/token

# OAuth2 client credentials
# How to obtain:
#   1. Run:  python tosca_cli.py identity apps      → note the Id of your app
#   2. Run:  python tosca_cli.py identity secrets <appId>
#   3. Or generate a new secret:  python tosca_cli.py identity new-secret <appId>
TOSCA_CLIENT_ID=your-client-id
TOSCA_CLIENT_SECRET=your-client-secret

# OAuth2 scope (default: tta – do not change unless instructed by Tricentis)
TOSCA_SCOPE=tta

# HTTP timeout in seconds (default: 30)
# TOSCA_TIMEOUT=30

# Set to "false" to disable SSL certificate verification (not recommended for production)
# TOSCA_VERIFY_SSL=true

# OpenAI API key – only required for the `ask` command
# TOSCA_OPENAI_KEY=sk-...


# ─────────────────────────────────────────────────────────────
# TOSCA Commander CLI (on-prem) — connection settings template
#
# These settings are read by tosca_commander_cli.py and are
# independent of the Tosca Cloud settings above. Set only the
# auth combo that matches your environment.
# Verify with: python tosca_commander_cli.py config test
# ─────────────────────────────────────────────────────────────

# Base URL of the Tosca REST API service.
# Either form is accepted — the CLI auto-appends /rest/toscacommander if missing.
# Self-hosted (Tricentis.Tosca.RestApiService): http://yourhost:1111
# Reverse-proxied via IIS:                       https://yourhost/rest/toscacommander
TOSCA_COMMANDER_BASE_URL=http://yourhost:1111/rest/toscacommander

# Default workspace. Skip --workspace/-w on subcommands when this is set.
# Example: TOSCA_COMMANDER_WORKSPACE=MyWorkspace
TOSCA_COMMANDER_WORKSPACE=

# Auth mode (default: auto).
#   auto         → first matching combo: PAT → client-creds → Basic
#   basic        → BasicAuth (works for AD-backed multi-user workspaces)
#   pat          → Personal Access Token (Tricentis Server Repository)
#   client-creds → OAuth2 client_credentials at /tua/connect/token
#   negotiate    → IIS Windows Auth (NTLM/Kerberos via SSPI) — needs `pip install requests-negotiate-sspi`
#   ntlm         → explicit-cred NTLM — needs `pip install httpx-ntlm`
TOSCA_COMMANDER_AUTH=auto

# Mode: basic / ntlm / AD-as-basic
# TOSCA_COMMANDER_USER=DOMAIN\\user.name
# TOSCA_COMMANDER_PASSWORD=

# Mode: pat
# TOSCA_COMMANDER_TOKEN=

# Mode: client-creds (OAuth2 against Tosca Server's /tua/connect/token)
# TOSCA_COMMANDER_CLIENT_ID=
# TOSCA_COMMANDER_CLIENT_SECRET=
